<div class="fr-bg-grey fr-mb-2w">
  <div class="authorization-request-form-header">
    <div class="fr-container">
      <div class="fr-grid-row">
        <div class="fr-col-12 fr-col-md-8">
          <h1 class="authorization-request-form-header__name">
            <%= @authorization_request.definition.name  %>
          </h1>
        </div>
        <div class="fr-col-12 fr-col-md-4">
          <div class="authorization-request-form-header__actions">
            <% if policy([:instruction, @authorization_request_instructor_draft]).invite? %>
              <%= dsfr_main_modal_button(t('instruction.authorization_request_instructor_drafts.index.table.actions.invite'), new_instruction_authorization_request_instructor_draft_invite_applicant_to_claim_authorization_request_instructor_draft_path(@authorization_request_instructor_draft), class: 'fr-btn', aria: { controls: 'main-modal' }, data: { turbo_frame: 'main-modal-content' }) %>
            <% elsif policy([:instruction, @authorization_request_instructor_draft]).invite_link? %>
              <%= link_to t('instruction.authorization_request_instructor_drafts.index.table.actions.invite_link'), claim_authorization_request_instructor_draft_path(@authorization_request_instructor_draft.public_id), target: '_blank' %>

            <% end %>

            <% if policy([:instruction, @authorization_request_instructor_draft]).destroy? %>
              <%= button_to t('instruction.authorization_request_instructor_drafts.index.table.actions.delete'), instruction_authorization_request_instructor_draft_path(@authorization_request_instructor_draft), method: :delete, data: { turbo_confirm: t('instruction.authorization_request_instructor_drafts.index.table.actions.confirm_delete') }, class: 'fr-btn fr-btn--secondary fr-btn--sm' %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render 'shared/alerts' %>

<%= form_with(
  model: @authorization_request,
  url: @authorization_request_instructor_draft.new_record? ? instruction_authorization_request_instructor_drafts_path : instruction_authorization_request_instructor_draft_path(@authorization_request_instructor_draft),
  method: @authorization_request_instructor_draft.new_record? ? :post : :patch,
  builder: AuthorizationRequestFormFromInstructorBuilder
) do |f| %>
  <div class="fr-container">
    <% @authorization_request.definition.blocks.each do |block| %>
      <%= render_custom_editable_block_or_default(@authorization_request, block[:name], { f: }) %>
    <% end %>
  </div>

  <% if @authorization_request_instructor_draft.new_record? %>
    <%= f.hidden_field :type %>
  <% end %>

  <div class="fr-my-5w fr-py-2w sticky-bar" data-controller="sticky-bar">
    <div class="fr-container-fluid">
      <div class="fr-container">
        <div class="fr-btns-group fr-btns-group--inline fr-btns-group--icon-left fr-btns-group--right">
          <%= f.button t('.save'), name: :save, type: :submit, id: :save_authorization_request, class: %w(fr-btn fr-btn--secondary fr-icon-save-line fr-btn--icon-left fr-mb-0) %>
        </div>
      </div>
    </div>
  </div>
<% end %>
