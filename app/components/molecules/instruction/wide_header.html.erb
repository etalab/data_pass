<div class="fr-background-alt--blue-france fr-py-4w fr-mb-4w">
  <div class="fr-container">
    <% if breadcrumbs.present? %>
      <%= helpers.dsfr_breadcrumbs(html_attributes: { class: 'fr-mt-0 fr-mb-2w' }) do |b|
            breadcrumbs.each do |crumb|
              b.with_breadcrumb(label: crumb[:label], href: crumb[:href])
            end
          end %>
    <% end %>

    <div class="fr-grid-row fr-grid-row--middle fr-grid-row--gutters">
      <div class="fr-grid-row fr-grid-row--top fr-grid-row--gutters fr-col">
        <% if logo_asset&.attached? || dsfr_logo.present? %>
          <div class="fr-col-auto">
            <% if logo_asset&.attached? %>
              <%= image_tag logo_asset, alt: '', class: 'wide-header-logo' %>
            <% elsif dsfr_logo.present? %>
              <%= dsfr_pictogram(dsfr_logo) %>
            <% end %>
          </div>
        <% end %>
        <div class="fr-col">
          <h1 class="fr-mb-1v">
            <%= title %>
          </h1>
          <%= subtitle_content %>
        </div>
      </div>

      <% if right_content %>
        <div class="fr-col-auto">
          <%= right_content %>
        </div>
      <% end %>
    </div>
  </div>
</div>
