<turbo-frame id="main-modal-content">
  <div class="fr-modal__content">
    <h1 class="fr-modal__title">
      <%= t('.title') %>
    </h1>
    <p><%= t('.description', email: @user.email) %></p>
  </div>

  <div class="fr-modal__footer">
    <div class="fr-btns-group fr-btns-group--right fr-btns-group--inline-reverse fr-btns-group--inline-lg">
      <%= link_to t('.cancel'), '#', class: 'fr-btn fr-btn--secondary', aria: { controls: 'main-modal' } %>
      <%= button_to t('.confirm'), admin_ban_path(@user), method: :delete, class: 'fr-btn fr-btn--warning' %>
    </div>
  </div>
</turbo-frame>
