<!DOCTYPE html>
<html lang="fr">
  <head>
    <title>DataPass</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "dsfr-fonts", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "dsfr", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "dsfr-utility", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "dsfr-extensions", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%  Dir[Rails.root.join("app/assets/stylesheets/components/*.css")].each do |path| %>
      <%= stylesheet_link_tag "components/#{File.basename(path)}", "data-turbo-track": "reload" %>
    <% end %>

    <%  Dir[Rails.root.join("app/assets/stylesheets/pages/*.css")].each do |path| %>
      <%= stylesheet_link_tag "pages/#{File.basename(path)}", "data-turbo-track": "reload" %>
    <% end %>

    <%= javascript_include_tag "dsfr.module", "data-turbo-track": "reload" %>

    <%= javascript_importmap_tags %>

    <%= render partial: 'shared/favicons' %>
    <%= render partial: 'shared/matomo' %>
  </head>

  <body>
    <div class="fr-skiplinks">
      <nav class="fr-container" role="navigation" aria-label="Accès rapide">
        <ul class="fr-skiplinks__list">
          <li>
            <a class="fr-link" href="#content"><%= content_for?(:content_skip_link_text) ? yield(:content_skip_link_text) : "Contenu" %></a>
          </li>
          <% if content_for?(:skip_links) %>
            <%= yield(:skip_links) %>
          <% else %>
            <li>
              <a class="fr-link" href="#header">Menu</a>
            </li>
            <li>
              <a class="fr-link" href="#footer">Pied de page</a>
            </li>
          <% end %>
        </ul>
      </nav>
    </div>

    <%= render layout: 'shared/modal', locals: { id: 'main-modal' } do %>
      <%= render partial: 'shared/loader' %>
    <% end %>

    <% if content_for?(:extra_modal) %>
      <%= yield(:extra_modal) %>
    <% end %>

    <%= render partial: 'layouts/header' %>

    <main id="content">
      <% if content_for?(:body) %>
        <%= yield(:body) %>
      <% else %>
        <%= yield %>
      <% end %>
    </main>

    <%= render partial: 'layouts/footer' %>
  </body>
</html>
