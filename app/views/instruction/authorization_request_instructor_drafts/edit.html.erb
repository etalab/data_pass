<div class="fr-container">
  <h2 class="fr-h2 fr-mt-5w">
    <% if @authorization_request_instructor_draft.new_record? %>
      <%= t('.new_title', definition_name: @authorization_request.definition.name) %>
    <% else %>
      <%= t('.edit_title', definition_name: @authorization_request.definition.name) %>
    <% end %>
  </h2>

  <%= render 'shared/alerts' %>
</div>


<%= form_with(
  model: @authorization_request,
  url: @authorization_request_instructor_draft.new_record? ? instruction_authorization_request_instructor_drafts_path : instruction_authorization_request_instructor_draft_path(@authorization_request_instructor_draft),
  method: @authorization_request_instructor_draft.new_record? ? :post : :patch,
  builder: AuthorizationRequestFormFromInstructorBuilder
) do |f| %>
  <div class="fr-container">
    <% @authorization_request.definition.blocks.each do |block| %>
      <%= render_custom_editable_block_or_default(@authorization_request, block[:name], { f: }) %>
    <% end %>
  </div>

  <% if @authorization_request_instructor_draft.new_record? %>
    <%= f.hidden_field :type %>
  <% end %>

  <div class="fr-my-5w fr-py-2w sticky-bar" data-controller="sticky-bar">
    <div class="fr-container-fluid">
      <div class="fr-container">
        <div class="fr-btns-group fr-btns-group--inline fr-btns-group--icon-left fr-btns-group--right">
          <%= link_to t('.cancel'), instruction_authorization_request_instructor_drafts_path, class: %w(fr-btn fr-btn--secondary fr-icon-close-line fr-btn--icon-left fr-mb-0) %>

          <%= f.button t('.save'), name: :save, type: :submit, id: :save_authorization_request, class: %w(fr-btn fr-btn--secondary fr-icon-save-line fr-btn--icon-left fr-mb-0) %>
        </div>
      </div>
    </div>
  </div>
<% end %>
