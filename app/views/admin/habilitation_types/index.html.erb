<% content_for(:skip_links) do %>
  <%= skip_link t('.skip_to_list'), '#habilitation-types-list' %>
<% end %>

<% set_title! t('page_titles.admin_habilitation_types') %>

<%= content_for(:header_action) do %>
  <% if policy(HabilitationType).new? %>
    <%= link_to t('.new'), new_admin_habilitation_type_path, class: %w[fr-btn fr-btn--icon-left fr-icon-add-circle-line] %>
  <% end %>
<% end %>

<div class="fr-table fr-table--bordered" id="habilitation-types-list">
  <div class="fr-table__container">
    <div class="fr-table__content">
      <table class="admin-habilitation-types-table">
        <caption class="fr-sr-only"><%= t('page_titles.admin_habilitation_types') %></caption>
        <thead>
          <tr>
            <th scope="col"><%= t('.table.name') %></th>
            <th scope="col"><%= t('.table.provider') %></th>
            <th scope="col" class="fr-cell--center"><%= t('.table.kind') %></th>
            <th scope="col" class="fr-cell--center"><%= t('.table.created_at') %></th>
            <th scope="col" class="fr-cell--center"><%= t('.table.requests_count') %></th>
            <th scope="col" class="fr-cell--center"><%= t('.table.actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% if @habilitation_types.empty? %>
            <tr>
              <td colspan="6"><%= t('.empty') %></td>
            </tr>
          <% else %>
            <% @habilitation_types.each do |habilitation_type| %>
              <tr id="<%= dom_id(habilitation_type) %>">
                <td class="text-wrap-cell"><%= link_to habilitation_type.name, admin_habilitation_type_path(habilitation_type) %></td>
                <td class="text-wrap-cell"><%= habilitation_type.data_provider.name %></td>
                <td class="fr-cell--center"><%= t("admin.habilitation_types.form.kinds.#{habilitation_type.kind}") %></td>
                <td class="fr-cell--center"><%= l(habilitation_type.created_at.to_date) %></td>
                <td class="fr-cell--center"><%= habilitation_type.authorization_requests_count %></td>
                <td class="fr-cell--center">
                  <ul class="fr-btns-group fr-btns-group--inline fr-btns-group--sm">
                    <% if policy(habilitation_type).edit? %>
                      <li>
                        <%= link_to t('.edit'), edit_admin_habilitation_type_path(habilitation_type),
                            class: %w[fr-btn fr-btn--sm fr-btn--tertiary fr-icon-edit-line fr-btn--icon-left],
                            aria: { label: "#{t('.edit')} #{habilitation_type.name}" } %>
                      </li>
                    <% end %>
                    <% if policy(habilitation_type).destroy? %>
                      <li>
                        <%= button_to t('.delete'), admin_habilitation_type_path(habilitation_type),
                            method: :delete,
                            class: %w[fr-btn fr-btn--sm fr-btn--tertiary fr-btn--icon-left fr-icon-delete-line fr-text-default--error],
                            aria: { label: "#{t('.delete')} #{habilitation_type.name}" },
                            data: { turbo_confirm: t('.confirm_delete', name: habilitation_type.name) } %>
                      </li>
                    <% end %>
                  </ul>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%= paginate @habilitation_types %>
