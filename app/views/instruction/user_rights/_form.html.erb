<%= form_with model: form,
              url: url,
              method: method,
              scope: :instruction_user_right_form,
              builder: DsfrFormBuilder do |f| %>

  <% if form.errors.any? %>
    <%= dsfr_alert type: :error,
                   title: t('errors.messages.form_errors', count: form.errors.count),
                   html_attributes: { class: 'fr-mb-4w' } do %>
      <ul class="fr-messages-group">
        <% form.errors.full_messages.each do |message| %>
          <li class="fr-message fr-message--error"><%= message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%= render 'instruction/user_rights/identity_card',
    form_builder: show_email_field ? f : nil,
    target_user: target_user %>

  <section class="fr-panel fr-mb-3w fr-p-3w" aria-labelledby="user-rights-rights-section">
    <h2 id="user-rights-rights-section" class="fr-h5 fr-text-title--blue-france fr-mb-3w">
      <%= t('instruction.user_rights.new.rights_section') %>
    </h2>

    <%= dsfr_accordion t('instruction.user_rights.new.roles_help.title'),
                       id: 'user-rights-roles-help',
                       class: ['fr-mb-3w'] do %>
      <%= render 'instruction/user_rights/roles_help' %>
    <% end %>

    <%= render Molecules::Instruction::UserRights::ReadonlyRightsListComponent.new(rights: readonly_rights) %>

    <div data-controller="nested-form">
      <div data-nested-form-target="target">
        <% form.rights.each_with_index do |right, index| %>
          <%= render Molecules::Instruction::UserRights::RightFieldComponent.new(
            index: index,
            scope: right[:scope],
            role_type: right[:role_type],
            permissions: permissions
          ) %>
        <% end %>
      </div>

      <script type="text/x-template" data-nested-form-target="template">
        <%= render Molecules::Instruction::UserRights::RightFieldComponent.new(
          index: 'NEW',
          scope: '',
          role_type: '',
          permissions: permissions
        ) %>
      </script>

      <div class="fr-mt-2w">
        <button type="button"
                class="fr-btn fr-btn--secondary fr-btn--icon-left fr-icon-add-line"
                data-action="click->nested-form#add"
                id="add-right-button">
          <%= t('instruction.user_rights.new.add_right') %>
        </button>
      </div>
    </div>
  </section>

  <ul class="fr-btns-group fr-btns-group--right fr-btns-group--inline-lg fr-btns-group--icon-left">
    <li>
      <%= link_to t('instruction.user_rights.new.cancel'),
            user_rights_index_path,
            class: %w[fr-btn fr-btn--secondary] %>
    </li>
    <li>
      <%= f.button submit_label, type: :submit, class: %w[fr-btn fr-btn--primary fr-icon-check-line fr-btn--icon-left] %>
    </li>
  </ul>
<% end %>
