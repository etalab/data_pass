<% set_title! t('page_titles.instruction_definition_forms', definition_name: @authorization_definition.name_with_stage) %>

<%= render Molecules::Instruction::AuthorizationDefinition::FormsHeaderComponent.new(
      authorization_definition: @authorization_definition) %>

<div class="fr-container" data-controller="search-list">
  <label class="fr-label fr-mb-1w" for="form-search"><%= t('.search.label') %></label>

  <div class="fr-grid-row fr-grid-row--middle fr-grid-row--gutters fr-mb-3w">
    <div class="fr-col-12 fr-col-md-6">
      <div class="fr-search-bar" role="search">
        <input class="fr-input" type="search" id="form-search"
               placeholder="<%= t('.search.placeholder') %>"
               data-search-list-target="input"
               data-action="input->search-list#filter">
        <button class="fr-btn" title="<%= t('.search.submit') %>">
          <%= t('.search.submit') %>
        </button>
      </div>
    </div>
    <p class="fr-col fr-mb-0 definitions-search-count" data-search-list-target="count"
       data-templates="<%= { zero: t('.search.results_count.zero'), one: t('.search.results_count.one', count: 1), other: t('.search.results_count.other', count: '%{count}') }.to_json %>">
      <%= t('.search.results_count', count: @forms.size) %>
    </p>
  </div>

  <% if @forms.empty? %>
    <p class="fr-text--lg"><%= t('.empty') %></p>
  <% else %>
    <ul class="fr-raw-list fr-grid-row fr-grid-row--gutters">
      <% @forms.each do |form| %>
        <li class="fr-col-12 fr-col-md-6" id="<%= dom_id(form) %>"
            data-search-list-target="item"
            data-search-text="<%= I18n.transliterate([form.name, form.uid].compact_blank.join(' ')).downcase %>">
          <%= render Molecules::Instruction::Form::CardComponent.new(
                authorization_request_form: form,
                validated_count: @counts_by_form[form.uid][:validated],
                submitted_count: @counts_by_form[form.uid][:submitted]) %>
        </li>
      <% end %>
    </ul>
    <p class="fr-text--sm fr-mt-3w fr-hidden" data-search-list-target="emptyMessage"><%= t('.search.no_results') %></p>
  <% end %>
</div>
