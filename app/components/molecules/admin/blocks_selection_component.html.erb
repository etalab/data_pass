<fieldset class="fr-fieldset" id="blocks-fieldset" aria-labelledby="blocks-fieldset-legend">
  <legend class="fr-fieldset__legend fr-h3" id="blocks-fieldset-legend">
    <%= title %>
  </legend>
  <div class="fr-fieldset__content">
    <%= form.hidden_field :blocks, value: '', name: 'habilitation_type[blocks][]' %>
    <% HabilitationType::BLOCK_ORDER.each do |block_name| %>
      <div class="fr-checkbox-group">
        <input type="checkbox"
               name="habilitation_type[blocks][]"
               value="<%= block_name %>"
               id="block_<%= block_name %>"
               <%= 'checked' if checked_blocks.include?(block_name) %>>
        <label class="fr-label" for="block_<%= block_name %>">
          <%= t("admin.habilitation_types.form.blocks.#{block_name}") %>
        </label>
      </div>
    <% end %>
  </div>
</fieldset>