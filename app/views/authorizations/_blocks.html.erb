<% authorization_request.blocks.each do |block| %>
  <% next if block[:name].to_s == 'contacts' && displayed_on_a_public_page? %>

  <% form_builder = AuthorizationRequestFormBuilder.new(
    "authorization_request",
    authorization_request,
    self,
    {}
  ) %>

  <%= render_custom_block_or_default(authorization_request, block[:name], f: form_builder, editable: false) %>
<% end %>