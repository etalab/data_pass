<h2 class="fr-h2 fr-mb-4w">Volumes sur la période</h2>
<div class="fr-grid-row fr-grid-row--gutters fr-mb-6w">
  <%= render 'stats/shared/stat_card',
    controller_name: controller_name,
    title: 'Nouvelles demandes',
    target: 'newRequestsCount',
    bg_color: '#e3e3fd',
    value_color: '#000091',
    text_align: 'center',
    col_classes: 'fr-col-12 fr-col-md-6 fr-col-lg-3',
    title_class: 'fr-text--md',
    value_class: 'fr-display--xs' %>

  <%= render 'stats/shared/stat_card',
    controller_name: controller_name,
    title: 'Réouvertures',
    target: 'reopeningsCount',
    bg_color: '#fef7da',
    value_color: '#fc5d00',
    text_align: 'center',
    col_classes: 'fr-col-12 fr-col-md-6 fr-col-lg-3',
    title_class: 'fr-text--md',
    value_class: 'fr-display--xs' %>

  <%= render 'stats/shared/stat_card',
    controller_name: controller_name,
    title: 'Validations',
    target: 'validationsCount',
    bg_color: '#b8fec9',
    value_color: '#18753c',
    text_align: 'center',
    col_classes: 'fr-col-12 fr-col-md-6 fr-col-lg-3',
    title_class: 'fr-text--md',
    value_class: 'fr-display--xs' %>

  <%= render 'stats/shared/stat_card',
    controller_name: controller_name,
    title: 'Refus',
    target: 'refusalsCount',
    bg_color: '#ffe9e6',
    value_color: '#ce0500',
    text_align: 'center',
    col_classes: 'fr-col-12 fr-col-md-6 fr-col-lg-3',
    title_class: 'fr-text--md',
    value_class: 'fr-display--xs' %>
</div>
