<!-- Date range picker -->
<div class="fr-mb-4w">
  <!-- Custom date pickers first -->
  <div class="fr-grid-row fr-grid-row--center fr-mb-3w">
    <div class="fr-col-auto">
      <div style="display: flex; align-items: center; gap: 1rem;">
        <label for="startDate" class="fr-label fr-mb-0" style="white-space: nowrap;">Du</label>
        <input type="date" id="startDate" class="fr-input" data-<%= controller_name %>-target="startDate" data-action="input-><%= controller_name %>#updateFiltersDebounced" style="width: 180px;" />
        <label for="endDate" class="fr-label fr-mb-0" style="white-space: nowrap;">au</label>
        <input type="date" id="endDate" class="fr-input" data-<%= controller_name %>-target="endDate" data-action="input-><%= controller_name %>#updateFiltersDebounced" style="width: 180px;" />
      </div>
    </div>
  </div>
  
  <!-- Quick presets below -->
  <div class="fr-grid-row fr-grid-row--center">
    <div class="fr-col-12">
      <div class="fr-btns-group fr-btns-group--inline-md fr-btns-group--center" data-<%= controller_name %>-target="quickRanges">
        <button class="fr-btn fr-btn--sm fr-btn--tertiary-no-outline" type="button" data-action="click-><%= controller_name %>#setDateRange" data-range="last-30-days">
          30 derniers jours
        </button>
        <button class="fr-btn fr-btn--sm fr-btn--tertiary-no-outline" type="button" data-action="click-><%= controller_name %>#setDateRange" data-range="last-3-months">
          3 derniers mois
        </button>
        <button class="fr-btn fr-btn--sm fr-btn--tertiary-no-outline" type="button" data-action="click-><%= controller_name %>#setDateRange" data-range="last-year">
          12 derniers mois
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Other filters - second row -->
<div class="fr-grid-row fr-grid-row--center fr-grid-row--gutters fr-mb-2w">
  <!-- Fournisseurs de données -->
  <div class="fr-col-12 fr-col-md-4">
    <div class="fr-select-group">
      <label class="fr-label">Fournisseur de données</label>
      <select class="fr-select" data-<%= controller_name %>-target="providerSelect" data-action="change-><%= controller_name %>#updateFilters">
        <option value="">Tous les fournisseurs</option>
      </select>
    </div>
  </div>
  
  <!-- Types d'habilitation -->
  <div class="fr-col-12 fr-col-md-4">
    <div class="fr-select-group">
      <label class="fr-label">Type d'habilitation</label>
      <select class="fr-select" data-<%= controller_name %>-target="typeSelect" data-action="change-><%= controller_name %>#updateFilters">
        <option value="">Tous les types</option>
      </select>
    </div>
  </div>
  
  <!-- Formulaires -->
  <div class="fr-col-12 fr-col-md-4">
    <div class="fr-select-group">
      <label class="fr-label">Formulaire</label>
      <select class="fr-select" data-<%= controller_name %>-target="formSelect" data-action="change-><%= controller_name %>#updateFilters">
        <option value="">Tous les formulaires</option>
      </select>
    </div>
  </div>
</div>

<!-- Clear filters button -->
<div class="fr-grid-row fr-grid-row--center fr-mb-6w">
  <div class="fr-col-auto">
    <button class="fr-btn fr-btn--secondary fr-btn--sm" type="button" data-action="click-><%= controller_name %>#clearFilters">
      Réinitialiser les filtres
    </button>
  </div>
</div>
