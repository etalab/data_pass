<div class="fr-callout fr-my-16v">
  <h3 class="fr-callout__title">
    <%= t('authorization_requests.show.access_callout.title') %>
  </h3>

  <%= simple_format t('authorization_requests.show.access_callout.content', access_name: authorization_request.name),
                   { class: 'fr-callout__text' }, wrapper_tag: 'p' %>

  <%= link_to t('authorization_requests.show.access_callout.button'),
              authorization_request.access_link,
              class: 'fr-btn fr-btn--icon-right fr-icon-external-link-line',
              target: '_blank' %>
</div>
