<div class="fr-grid-row fr-grid-row--gutters fr-mb-6w">
  <%= render 'stats/shared/stat_card',
    controller_name: controller_name,
    title: 'Demandes soumises',
    target: 'totalRequestsCount',
    subtitle_target: 'reopeningsCount',
    bg_color: '#e3e3fd',
    value_color: '#000091',
    col_classes: 'fr-col-12 fr-col-md-6 fr-col-lg-4' %>

  <%= render 'stats/shared/stat_card',
    controller_name: controller_name,
    title: 'Demandes validées',
    target: 'validationsCount',
    bg_color: '#b8fec9',
    value_color: '#18753c',
    col_classes: 'fr-col-12 fr-col-md-6 fr-col-lg-4' %>

  <%= render 'stats/shared/stat_card',
    controller_name: controller_name,
    title: 'Demandes refusées',
    target: 'refusalsCount',
    bg_color: '#ffe9e6',
    value_color: '#ce0500',
    col_classes: 'fr-col-12 fr-col-md-6 fr-col-lg-4' %>
</div>
