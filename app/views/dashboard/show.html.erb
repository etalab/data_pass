<% content_for :content_skip_link_text do %>
  Tableau de bord
<% end %>

<% content_for :skip_links do %>
  <% if @authorization_requests.changes_requested.without_reopening.any? %>
    <%= skip_link("Demandes à modifier", "changes-requested-section") %>
  <% end %>
  <% if @authorization_requests.in_instructions.without_reopening.any? %>
    <%= skip_link("Demandes en cours d'instruction", "pending-section") %>
  <% end %>
  <% if @authorization_requests.drafts.without_reopening.any? %>
    <%= skip_link("Brouillons", "draft-section") %>
  <% end %>
  <% if @authorization_requests.validated_or_refused.any? %>
    <%= skip_link("Mes habilitations", "validated-refused-section") %>
  <% end %>
  <%= skip_link("Menu", "header") %>
  <%= skip_link("Pied de page", "footer") %>
<% end %>

<% if @authorization_requests.any? %>
  <% if @authorization_requests.changes_requested.without_reopening.any? %>
    <div id="changes-requested-section">
      <%= render partial: 'authorization_requests_changes_requested', locals: { authorization_requests: @authorization_requests.changes_requested.without_reopening, kind: 'changes_requested' } %>
    </div>
  <% end %>

  <% if @authorization_requests.in_instructions.without_reopening.any? %>
    <div id="pending-section">
      <%= render partial: 'authorization_requests', locals: { authorization_requests: @authorization_requests.in_instructions.without_reopening, kind: 'pending' } %>
    </div>
  <% end %>

  <% if @authorization_requests.drafts.without_reopening.any? %>
    <div id="draft-section">
      <%= render partial: 'authorization_requests', locals: { authorization_requests: @authorization_requests.drafts.without_reopening, kind: 'draft' } %>
    </div>
  <% end %>

  <% if @authorization_requests.validated_or_refused.any? %>
    <div id="validated-refused-section">
      <%= render partial: 'authorization_requests', locals: { authorization_requests: @authorization_requests.validated_or_refused, kind: 'validated_or_refused' } %>
    </div>
  <% end %>
<% else %>
  <h3 class="center">
    <%= t(".no_authorization_requests.#{params[:id]}") %>
  </h3>
<% end %>
