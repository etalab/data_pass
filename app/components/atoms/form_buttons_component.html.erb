<div>
  <% if initiate_request_path %>
    <div class="fr-mb-1w">
      <%= link_to t('instruction.authorization_definitions.show.initiate_request'),
            initiate_request_path,
            class: 'fr-btn fr-btn--icon-left fr-icon-draft-line authorization-definition-action-btn' %>
    </div>
  <% end %>
  <div data-controller="clipboard"
       data-clipboard-content-value="<%= copy_request_url %>"
       data-clipboard-original-message-value="<%= t('instruction.authorization_definitions.show.copy_request_link') %>">
    <button class="fr-btn fr-btn--secondary fr-btn--icon-left fr-icon-clipboard-line authorization-definition-action-btn"
            data-action="click->clipboard#copy">
      <%= t('instruction.authorization_definitions.show.copy_request_link') %>
    </button>
  </div>
</div>
