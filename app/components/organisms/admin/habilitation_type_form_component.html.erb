<div id="habilitation-type-form">
  <%= form_with(
    model: [:admin, @habilitation_type],
    builder: DsfrFormBuilder
  ) do |f| %>

    <div class="fr-mb-4w">
      <h2 class="fr-h3"><%= t('admin.habilitation_types.form.sections.general') %></h2>

      <%= render Molecules::Admin::NameWithUidPreviewComponent.new(
        form: f,
        record: @habilitation_type,
        uid_label: t('admin.habilitation_types.form.uid_preview_label')
      ) %>

      <%= f.dsfr_text_area :description %>

      <%= f.dsfr_select :data_provider_id,
          @data_providers.map { |data_provider| [data_provider.name, data_provider.id] },
          required: true,
          include_blank: t('admin.habilitation_types.form.select_provider') %>

      <%= f.dsfr_radio_buttons :kind,
          HabilitationType.kinds.keys,
          required: true %>

      <%= f.dsfr_text_area :form_introduction %>
    </div>

    <div class="fr-mb-4w">
      <h2 class="fr-h3"><%= t('admin.habilitation_types.form.sections.links') %></h2>

      <%= f.dsfr_text_field :link %>
      <%= f.dsfr_text_field :cgu_link %>
      <%= f.dsfr_text_field :access_link %>
    </div>

    <div class="fr-mb-4w">
      <%= render Molecules::Admin::BlocksSelectionComponent.new(
        form: f,
        habilitation_type: @habilitation_type
      ) %>
    </div>

    <div data-controller="blocks-toggle"
         data-blocks-toggle-block-name-value="scopes">
      <div data-blocks-toggle-target="section">
        <div class="fr-mb-4w">
          <h2 class="fr-h3"><%= t('admin.habilitation_types.form.scopes_editor.title') %></h2>
          <%= render Molecules::Admin::ScopesEditorComponent.new(
            form: f,
            habilitation_type: @habilitation_type
          ) %>
        </div>
      </div>
    </div>

    <div data-controller="blocks-toggle"
         data-blocks-toggle-block-name-value="contacts">
      <div data-blocks-toggle-target="section">
        <div class="fr-mb-4w">
          <%= render Molecules::Admin::ContactTypesSelectorComponent.new(
            form: f,
            habilitation_type: @habilitation_type
          ) %>
        </div>
      </div>
    </div>

    <ul class="fr-btns-group fr-btns-group--inline">
      <li>
        <%= link_to t('admin.habilitation_types.form.cancel'), admin_habilitation_types_path,
            class: %w[fr-btn fr-btn--tertiary] %>
      </li>
      <li class="fr-ml-auto">
        <%= f.button @habilitation_type.new_record? ? t('admin.habilitation_types.form.submit_new') : t('admin.habilitation_types.form.submit_edit'),
            type: :submit, class: %w[fr-btn] %>
      </li>
    </ul>

  <% end %>
</div>
