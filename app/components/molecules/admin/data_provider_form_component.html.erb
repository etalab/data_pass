<div id="<%= inline? ? 'new-data-provider-form' : 'data-provider-form' %>">
  <%= form_with(
    model: [:admin, data_provider],
    url: (admin_data_providers_path if inline?),
    builder: DsfrFormBuilder,
    html: { novalidate: inline? },
    data: {}
  ) do |f| %>

    <% if data_provider.errors.any? %>
      <div class="fr-alert fr-alert--error fr-mb-3v" role="alert">
        <ul class="fr-messages-group">
          <% data_provider.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.dsfr_text_field :name, required: true %>
    <%= f.dsfr_text_field :link, required: true %>
    <%= f.dsfr_file_field :logo %>

    <div class="fr-btns-group fr-btns-group--inline <%= 'fr-btns-group--sm' if inline? %>">
      <% if inline? %>
        <button type="button"
                class="fr-btn fr-btn--tertiary"
                data-action="click->toggle-section#close">
          <%= t('admin.data_providers.form.cancel') %>
        </button>
      <% else %>
        <%= link_to t('admin.data_providers.form.cancel'), admin_data_providers_path,
            class: %w[fr-btn fr-btn--tertiary] %>
      <% end %>
      <%= f.button submit_label, type: :submit, class: %w[fr-btn] %>
    </div>

  <% end %>
</div>