<% if @authorization_request.display_prefilled_banner_for_each_block? && @authorization_request.prefilled_data?(%i[cadre_juridique_nature cadre_juridique_url]) %>
  <%= render partial: "authorization_request_forms/shared/prefilled_banner" %>
<% end %>

<%= f.info_for(:legal) %>

<%= render Organisms::AuthorizationRequestForms::LegalFrameworkComponent.new(
  form: f,
  field_prefix: :cadre_juridique
) %>

<% if @authorization_request.france_connect_modality? && @authorization_request.france_connect_certified_form? %>
  <% if @authorization_request.france_connect_authorization_id.blank? %>
    <%= render Organisms::AuthorizationRequestForms::LegalFrameworkComponent.new(
      form: f,
      field_prefix: :fc_cadre_juridique
    ) %>
  <% else %>
    <div class="fr-callout fr-mb-3w">
      <p class="fr-callout__text">
        <%= t('authorization_request_forms.api_particulier.legal.fc_linked_readonly') %>
      </p>
    </div>
    <fieldset disabled>
      <%= render Organisms::AuthorizationRequestForms::LegalFrameworkComponent.new(
        form: f,
        field_prefix: :fc_cadre_juridique
      ) %>
    </fieldset>
  <% end %>
<% end %>
