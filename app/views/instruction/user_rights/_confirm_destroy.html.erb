<turbo-frame id="main-modal-content">
  <div class="fr-modal__content">
    <h1 id="fr-modal-title-main-modal" class="fr-modal__title">
      <%= t('instruction.user_rights.confirm_destroy.title', email: @target_user.email) %>
    </h1>

    <% if @modifiable_rights.any? %>
      <p><%= t('instruction.user_rights.confirm_destroy.warning') %></p>
      <ul>
        <% @modifiable_rights.each do |right| %>
          <li>
            <strong><%= Instruction::Scope.new(right[:scope]).label %></strong>
            <%= render Atoms::ColorBadgeComponent.for_role(right[:role_type], label: t("instruction.user_rights.roles.#{right[:role_type]}")) %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p id="no-modifiable-rights-msg"><%= t('instruction.user_rights.confirm_destroy.no_modifiable_rights') %></p>
    <% end %>
  </div>

  <div class="fr-modal__footer">
    <div class="fr-btns-group fr-btns-group--right fr-btns-group--inline-reverse fr-btns-group--inline-lg fr-btns-group--icon-left">
      <button type="button"
              class="fr-btn fr-btn--secondary"
              aria-controls="main-modal">
        <%= t('instruction.user_rights.confirm_destroy.cancel') %>
      </button>
      <%= button_to t('instruction.user_rights.confirm_destroy.submit'),
            instruction_user_right_path(@target_user),
            method: :delete,
            class: 'fr-btn fr-btn--warning fr-btn--icon-left fr-icon-delete-line',
            disabled: @modifiable_rights.empty?,
            aria: (@modifiable_rights.empty? ? { describedby: 'no-modifiable-rights-msg' } : {}) %>
    </div>
  </div>
</turbo-frame>
